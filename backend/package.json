{
  "name": "assetflow-backend",
  "version": "1.0.0",
  "description": "Backend API server for AssetFlow ERP & Asset Management system",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx src/db/seed.ts",
    "dev": "nodemon --watch src -e ts --exec tsx src/server.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "nodemon": "^3.1.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
